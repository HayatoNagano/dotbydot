{
  "name": "dotbydot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npx tsx server/index.ts",
    "dev:all": "concurrently -k -n server,client -c blue,green \"npx tsx server/index.ts\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
